# btc-rpc-explorer config for the Block Zero mainnet seed node.
# Copy to /opt/btc-rpc-explorer-mainnet/.env on the VPS.
# Separate install from the testnet explorer so branding (BLOZ vs TBLOZ) does not clash.
BTCEXP_HOST=127.0.0.1
BTCEXP_PORT=3003
BTCEXP_BITCOIND_HOST=127.0.0.1
BTCEXP_BITCOIND_PORT=8211
BTCEXP_BITCOIND_COOKIE=/opt/bzero-mainnet/.cookie
BTCEXP_ADDRESS_API=electrumx
BTCEXP_SLOW_DEVICE_MODE=false
BTCEXP_PRIVACY_MODE=true
BTCEXP_NO_RATES=true
BTCEXP_SITE_TITLE=Block Zero Explorer
BTCEXP_COIN=BTC
