# btc-rpc-explorer config for the Block Zero testnet seed node.
# Copy to /opt/btc-rpc-explorer/.env on the VPS.
BTCEXP_HOST=127.0.0.1
BTCEXP_PORT=3002
BTCEXP_BITCOIND_HOST=127.0.0.1
BTCEXP_BITCOIND_PORT=18211
BTCEXP_BITCOIND_COOKIE=/opt/bzero-testnet/testnet3/.cookie
BTCEXP_ADDRESS_API=electrumx
BTCEXP_SLOW_DEVICE_MODE=false
BTCEXP_PRIVACY_MODE=true
BTCEXP_NO_RATES=true
BTCEXP_SITE_TITLE=Block Zero Testnet Explorer
BTCEXP_COIN=BTC
