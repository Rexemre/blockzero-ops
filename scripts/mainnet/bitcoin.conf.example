# Block Zero MAINNET - copy to %LOCALAPPDATA%\BlockZeroMainnet\bitcoin.conf (Windows)
# or ~/.blockzero-mainnet/bitcoin.conf (Linux/macOS). Chain data lives in the datadir root.

server=1
txindex=1

[main]
listen=1
rpcbind=127.0.0.1
rpcallowip=127.0.0.1
# Local-only RPC. 8332 avoids the Hyper-V/WSL reserved-port range that blocks
# 8211 on some Windows hosts (error 10013). Change freely; it is not networked.
rpcport=8332
addnode=217.160.46.61:8210
